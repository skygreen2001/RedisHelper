{
  "name": "redis-helper",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/ws-proxy.js\" \"vite\"",
    "start": "node server/ws-proxy.js",
    "vite": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "cross-env TAURI=true tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac": "tauri build --target universal-apple-darwin",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-gnu",
    "tauri:build:all": "tauri build --target universal-apple-darwin && tauri build --target x86_64-pc-windows-gnu",
    "proxy": "node server/ws-proxy.js"
  },
  "dependencies": {
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "element-plus": "^2.4.4",
    "ioredis": "^5.10.1",
    "pinia": "^2.1.7",
    "redis": "^5.12.1",
    "sortablejs": "^1.15.7",
    "vue": "^3.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "typescript": "^5.2.2",
    "vite": "^8.0.12",
    "vue-tsc": "^2.2.12"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.60.3"
  }
}
